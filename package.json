{
  "name": "kanban-app",
  "version": "0.1.0",
  "private": true,
  "description": "Offline-first Kanban app — React Native + React Native Web",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/adapters/*"
  ],
  "scripts": {
    "mobile": "yarn workspace @kanban/mobile start",
    "web": "yarn workspace @kanban/web start",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit -p tsconfig.base.json"
  },
  "devDependencies": {
    "@babel/core": "^7.23.7",
    "@babel/plugin-proposal-decorators": "^7.23.7",
    "@babel/preset-env": "^7.23.7",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.23.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.11",
    "@types/react": "^18.2.48",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "react": "18.2.0",
    "react-native-web": "^0.19.10",
    "typescript": "^5.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": ["./jest.setup.ts"],
    "transform": {
      "^.+\\.[jt]sx?$": [
        "babel-jest",
        {
          "presets": [
            ["@babel/preset-env", { "targets": { "node": "current" } }],
            "@babel/preset-typescript",
            ["@babel/preset-react", { "runtime": "automatic" }]
          ],
          "plugins": [
            ["@babel/plugin-proposal-decorators", { "legacy": true }]
          ]
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(@nozbe/watermelondb|@kanban|react-native)/)"
    ],
    "moduleNameMapper": {
      "^@kanban/types$": "<rootDir>/packages/types/src/index.ts",
      "^@kanban/utils$": "<rootDir>/packages/utils/src/index.ts",
      "^@kanban/store$": "<rootDir>/packages/store/src/index.ts",
      "^@kanban/database$": "<rootDir>/packages/database/src/index.ts",
      "^@kanban/database/src/(.*)$": "<rootDir>/packages/database/src/$1",
      "^@kanban/services$": "<rootDir>/packages/services/src/index.ts",
      "^@kanban/ui$": "<rootDir>/packages/ui/src/index.ts",
      "^react-native$": "react-native-web",
      "^@react-native-async-storage/async-storage$": "<rootDir>/__mocks__/@react-native-async-storage/async-storage.ts"
    },
    "testPathIgnorePatterns": ["/node_modules/", "/apps/"]
  },
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=1.22.0"
  }
}

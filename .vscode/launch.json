{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to Metro (React Native)",
      "type": "reactnative",
      "request": "attach",
      "port": 8081
    },
    {
      "name": "Debug Web (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:8080",
      "webRoot": "${workspaceFolder}/apps/web/src",
      "sourceMapPathOverrides": {
        "webpack:///./src/*": "${webRoot}/*"
      }
    }
  ]
}
